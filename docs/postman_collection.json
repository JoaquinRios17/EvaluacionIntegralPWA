{
  "info": {
    "name": "Gestion de Cursos e Inscripciones - API",
    "description": "Coleccion para probar la API REST del proyecto integrador (Programacion Web II).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "curso_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registro",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Estudiante Prueba\",\n  \"email\": \"estudiante@correo.com\",\n  \"password\": \"123456\",\n  \"rol\": \"estudiante\"\n}"
            },
            "url": "{{base_url}}/auth/registro"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@cursos.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Perfil",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/perfil"
          }
        }
      ]
    },
    {
      "name": "Cursos",
      "item": [
        {
          "name": "Listar cursos (publico)",
          "request": { "method": "GET", "url": "{{base_url}}/cursos/publico" }
        },
        {
          "name": "Crear curso (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Programacion Web II\",\n  \"descripcion\": \"Curso integrador full stack\",\n  \"creditos\": 4,\n  \"cupoMaximo\": 30\n}"
            },
            "url": "{{base_url}}/cursos"
          }
        },
        {
          "name": "Actualizar curso (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"cupoMaximo\": 40\n}" },
            "url": "{{base_url}}/cursos/{{curso_id}}"
          }
        },
        {
          "name": "Eliminar curso (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/cursos/{{curso_id}}"
          }
        }
      ]
    },
    {
      "name": "Inscripciones",
      "item": [
        {
          "name": "Inscribirse a un curso",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"cursoId\": \"{{curso_id}}\"\n}" },
            "url": "{{base_url}}/inscripciones"
          }
        },
        {
          "name": "Listar mis inscripciones",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/inscripciones"
          }
        }
      ]
    },
    {
      "name": "Usuarios (admin)",
      "item": [
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/usuarios"
          }
        }
      ]
    }
  ]
}
